rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives & Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidSalesRecord(data) {
      return data.keys().hasAll(['date', 'storeId', 'productId', 'sales', 'promotion', 'holiday', 'temperature', 'fuelPrice', 'cpi', 'unemployment', 'userId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 13
        && data.date is string && data.date.size() <= 20
        && data.storeId is string && data.storeId.size() <= 100
        && data.productId is string && data.productId.size() <= 100
        && data.sales is number && data.sales >= 0
        && data.promotion in [0, 1]
        && data.holiday in [0, 1]
        && data.temperature is number
        && data.fuelPrice is number
        && data.cpi is number
        && data.unemployment is number
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'displayName', 'photoURL', 'createdAt'])
        && data.keys().size() == 4
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.photoURL is string && data.photoURL.size() <= 1024
        && data.createdAt is timestamp;
    }

    // --- Collection Rules ---

    match /salesRecords/{recordId} {
      allow get: if isOwner(existing().userId) && isValidId(recordId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(recordId)
        && isValidSalesRecord(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && isValidId(recordId)
        && isOwner(existing().userId)
        && isValidSalesRecord(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['sales', 'promotion', 'holiday', 'temperature', 'fuelPrice', 'cpi', 'unemployment', 'updatedAt', 'date', 'storeId', 'productId']);
        
      allow delete: if isOwner(existing().userId) && isValidId(recordId);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
    }
  }
}
